{
  "name": "co-sync",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "co-sync",
      "dependencies": {
        "co-sql": "file:../co-sql",
        "co-util": "file:../co-util",
        "cofound": "file:../.."
      }
    },
    "../..": {
      "version": "1.0.0-rc.2",
      "hasInstallScript": true,
      "dependencies": {
        "better-sqlite3": "^11.0.0",
        "debug": "^4.3.4",
        "esbuild": "0.24.0"
      },
      "bin": {
        "cofound": "bin/index.js"
      },
      "engines": {
        "node": ">=20.11"
      }
    },
    "../co-sql": {},
    "../co-util": {},
    "node_modules/co-sql": {
      "resolved": "../co-sql",
      "link": true
    },
    "node_modules/co-util": {
      "resolved": "../co-util",
      "link": true
    },
    "node_modules/cofound": {
      "resolved": "../..",
      "link": true
    }
  }
}
